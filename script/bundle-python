#!/usr/bin/env bash
# Downloads python-build-standalone CPython 3.11 for the current platform.
# Extracts, strips test suites/__pycache__/idle/tkinter to reduce size.
# Output: target/python-dist/{bin,lib,...}

set -euo pipefail

PYTHON_VERSION="3.11.11"
PBS_TAG="20250317"
ARCH=$(uname -m)

if [[ "$ARCH" != "x86_64" && "$ARCH" != "aarch64" ]]; then
    echo "Unsupported architecture: $ARCH"
    exit 1
fi

URL="https://github.com/indygreg/python-build-standalone/releases/download/${PBS_TAG}/cpython-${PYTHON_VERSION}+${PBS_TAG}-${ARCH}-unknown-linux-gnu-install_only_stripped.tar.gz"

echo "Downloading CPython ${PYTHON_VERSION} for ${ARCH}..."
echo "URL: ${URL}"

mkdir -p target
curl -L "$URL" -o target/python-standalone.tar.gz

echo "Extracting..."
rm -rf target/python-dist
mkdir -p target/python-dist
tar xzf target/python-standalone.tar.gz -C target/python-dist --strip-components=1

echo "Stripping unnecessary files..."
rm -rf target/python-dist/lib/python3.11/test
rm -rf target/python-dist/lib/python3.11/idlelib
rm -rf target/python-dist/lib/python3.11/tkinter
rm -rf target/python-dist/lib/python3.11/turtle*
rm -rf target/python-dist/lib/python3.11/turtledemo
rm -rf target/python-dist/lib/python3.11/ensurepip/_bundled/*.whl 2>/dev/null || true
find target/python-dist -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
find target/python-dist -name "*.pyc" -delete 2>/dev/null || true

echo "Done. Python distribution at target/python-dist/"
echo "Size: $(du -sh target/python-dist | cut -f1)"
